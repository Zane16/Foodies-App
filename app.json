{
  "expo": {
    "name": "Foodies",
    "slug": "Foodies-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/AppLogo.png",
    "scheme": "foodies",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodiesapp.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Foodies needs your location to help deliverers find you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Foodies needs your location to help deliverers find you.",
        "NSPhotoLibraryUsageDescription": "Foodies needs access to your photos to set your profile picture.",
        "NSCameraUsageDescription": "Foodies needs access to your camera to take a profile picture."
      }
    },
    "android": {
      "package": "com.foodiesapp.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/AppLogo.png",
        "backgroundColor": "#14B8A6"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "foodies",
              "host": "auth"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/AppLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/AppLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a193bde3-7db6-4b90-b338-dc6aaefaa8f1"
      }
    }
  }
}
